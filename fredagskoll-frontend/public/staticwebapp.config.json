{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/images/*.{png,jpg,jpeg,gif,webp,svg}",
      "/static/*",
      "/*.{css,js,json,ico,txt,map}"
    ]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  },
  "mimeTypes": {
    ".webp": "image/webp"
  }
}
